# Neon PostgreSQL — copy from your Neon dashboard
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Firebase Admin SDK — from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# Paste the private key exactly as shown (keep the \n literal line breaks)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

PORT=3001
